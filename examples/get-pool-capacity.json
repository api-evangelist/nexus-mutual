{
  "summary": "Get capacity for all products in pool 1",
  "request": {
    "method": "GET",
    "url": "https://api.nexusmutual.io/v2/capacity/pools/1",
    "parameters": {
      "period": 30
    }
  },
  "response": {
    "status": 200,
    "body": {
      "poolId": 1,
      "utilizationRate": 5000,
      "productsCapacity": [
        {
          "productId": 1,
          "availableCapacity": [
            {
              "assetId": 1,
              "amount": "1000000000000000000",
              "asset": {
                "id": 1,
                "symbol": "ETH",
                "decimals": 18
              }
            }
          ],
          "allocatedNxm": "500000000000000000",
          "minAnnualPrice": "0.025",
          "maxAnnualPrice": "0.1"
        }
      ]
    }
  }
}
